generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id                String   @id @default(cuid())
  osuId             Int      @unique
  username          String
  avatarUrl         String
  globalRank        Int?
  countryRank       Int?
  countryCode       String
  preferredModes    String[]
  languages         String[]
  timezone          String?
  taikoPp           Float?
  taikoGlobalRank   Int?
  catchPp           Float?
  catchGlobalRank   Int?
  maniaPp           Float?
  maniaGlobalRank   Int?
  tournamentOptIn   Boolean  @default(false)
  teamId            String?
  teamName          String?
  teamTag           String?
  teamFlagUrl       String?
  isRegistered      Boolean  @default(false)
  isOnline          Boolean  @default(false)
  pp                Float?
  lastSeen          DateTime?
  osuJoinDate       DateTime?
  aboutMe           String?
  playSchedule      String[]
  mapStyles         String[]
  discordUsername   String?
  twitchUsername    String?
  createdAt         DateTime @default(now())

  myRivals              UserRival[]    @relation("MyRivals")
  rivalOf               UserRival[]    @relation("RivalOf")

  playSessions          PlaySession[]
  sentRequests          FriendRequest[]        @relation("SentRequests")
  receivedRequests      FriendRequest[]        @relation("ReceivedRequests")
  tournamentParticipants TournamentParticipant[]
  sentRivalReqs         RivalRequest[]         @relation("SentRivalRequests")
  receivedRivalReqs     RivalRequest[]         @relation("ReceivedRivalRequests")
  rivalNotifiedPlays    RivalNotifiedPlay[]
  notifications         Notification[]
  snipesAsWatcher       SnipeChallenge[]     @relation("WatcherChallenges")
  snipesAsRival         SnipeChallenge[]     @relation("RivalChallenges")
  teamProfileOwned      TeamProfile?         @relation("TeamProfileOwner")
  teamApplications      TeamApplication[]
}

model UserRival {
  id        String   @id @default(cuid())
  userId    String
  rivalId   String
  createdAt DateTime @default(now())

  user  User @relation("MyRivals", fields: [userId],  references: [id])
  rival User @relation("RivalOf",  fields: [rivalId], references: [id])

  @@unique([userId, rivalId])
  @@index([userId])
}

model PlaySession {
  id         String @id @default(cuid())
  userId     String
  startHour  Int
  endHour    Int
  daysOfWeek Int[]

  user User @relation(fields: [userId], references: [id])
}

enum FriendRequestStatus {
  PENDING
  ACCEPTED
  DECLINED
}

enum RivalRequestStatus {
  PENDING
  ACCEPTED
  DECLINED
}

enum TournamentStatus {
  PENDING_VOTES
  SCHEDULED
  IN_PROGRESS
  CANCELLED
  COMPLETED
}

enum ParticipantStatus {
  INVITED
  ACCEPTED
  DECLINED
}

enum NotificationType {
  RIVAL_REQUEST
  RIVAL_PLAY
  TOURNAMENT_INVITE
  SNIPE
  TEAM_APPLICATION
}

enum TeamApplicationStatus {
  PENDING
  ACCEPTED
  DECLINED
}

enum SnipeChallengeStatus {
  OPEN
  SNIPED
  EXPIRED
}

model Tournament {
  id           String           @id @default(cuid())
  status       TournamentStatus @default(PENDING_VOTES)
  gameMode     String           @default("osu")
  scheduledFor  DateTime?
  reminderSent  Boolean          @default(false)
  createdAt     DateTime         @default(now())

  participants TournamentParticipant[]
}

model TournamentParticipant {
  id           String            @id @default(cuid())
  tournamentId String
  userId       String
  status       ParticipantStatus @default(INVITED)
  availability String?

  tournament Tournament @relation(fields: [tournamentId], references: [id], onDelete: Cascade)
  user       User       @relation(fields: [userId], references: [id])

  @@unique([tournamentId, userId])
}

model BotToken {
  id           String   @id @default("singleton")
  accessToken  String
  refreshToken String
  expiresAt    DateTime
  updatedAt    DateTime @updatedAt
}

model FriendRequest {
  id         String              @id @default(cuid())
  fromUserId String
  toUserId   String
  status     FriendRequestStatus @default(PENDING)
  createdAt  DateTime            @default(now())

  fromUser User @relation("SentRequests", fields: [fromUserId], references: [id])
  toUser   User @relation("ReceivedRequests", fields: [toUserId], references: [id])
}

model RivalRequest {
  id         String             @id @default(cuid())
  fromUserId String
  toUserId   String
  status     RivalRequestStatus @default(PENDING)
  createdAt  DateTime           @default(now())

  fromUser User @relation("SentRivalRequests", fields: [fromUserId], references: [id])
  toUser   User @relation("ReceivedRivalRequests", fields: [toUserId], references: [id])

  @@unique([fromUserId, toUserId])
}

model RivalNotifiedPlay {
  id         String   @id @default(cuid())
  userId     String
  osuScoreId String
  createdAt  DateTime @default(now())

  user User @relation(fields: [userId], references: [id])

  @@unique([userId, osuScoreId])
}

model LobbyDm {
  id          String   @id @default(cuid())
  senderOsuId Int
  targetOsuId Int
  sentAt      DateTime @default(now())

  @@index([senderOsuId, targetOsuId])
}

model MemberDm {
  id          String   @id @default(cuid())
  senderOsuId Int
  targetOsuId Int
  sentAt      DateTime @default(now())

  @@index([senderOsuId, targetOsuId])
}

model Notification {
  id        String           @id @default(cuid())
  userId    String
  type      NotificationType
  title     String
  body      String?
  link      String?
  read      Boolean          @default(false)
  createdAt DateTime         @default(now())

  user User @relation(fields: [userId], references: [id])
}

model TeamProfile {
  id              String   @id @default(cuid())
  teamOsuId       String   @unique
  name            String
  tag             String   @unique
  flagUrl         String?
  description     String
  isRecruiting    Boolean  @default(true)
  ppMin           Float?
  ppMax           Float?
  modes           String[]
  discordUrl      String?
  claimedByUserId String   @unique
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  claimedBy    User              @relation("TeamProfileOwner", fields: [claimedByUserId], references: [id])
  applications TeamApplication[]
}

model TeamApplication {
  id          String                @id @default(cuid())
  teamOsuId   String
  userId      String
  message     String
  status      TeamApplicationStatus @default(PENDING)
  createdAt   DateTime              @default(now())

  team TeamProfile @relation(fields: [teamOsuId], references: [teamOsuId])
  user User        @relation(fields: [userId], references: [id])

  @@unique([teamOsuId, userId])
}

model SnipeChallenge {
  id           String               @id @default(cuid())
  watcherId    String
  rivalId      String
  osuScoreId   String
  beatmapId    String
  beatmapsetId String
  mapTitle     String
  mapVersion   String
  targetPp     Float
  status       SnipeChallengeStatus @default(OPEN)
  createdAt    DateTime             @default(now())
  snipedAt     DateTime?

  watcher User @relation("WatcherChallenges", fields: [watcherId], references: [id])
  rival   User @relation("RivalChallenges",   fields: [rivalId],   references: [id])

  @@unique([watcherId, osuScoreId])
}
